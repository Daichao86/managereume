# ==========================================
# 简历人才管理系统 - 环境变量配置模板
# 复制为 .env 并填写真实值: cp .env.example .env
# ==========================================

# ---- 服务器配置 ----
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# ---- MySQL 数据库配置 ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=resume_user
DB_PASSWORD=your_mysql_password
DB_NAME=resume_db

# ---- 本地文件存储配置 ----
# 简历原件存储目录（绝对路径，确保 Node.js 进程有读写权限）
# 建议与项目代码分离存放，便于升级维护
UPLOAD_DIR=/data/resume-talent-mgr/uploads

# ---- OpenAI / AI 解析配置（可选）----
# 若不配置，用户需在系统设置页面手动填写
OPENAI_API_KEY=
# 若使用国内兼容接口（如 Azure OpenAI / 代理），请修改此项
OPENAI_BASE_URL=https://api.openai.com/v1
