# ==========================================
# 简历人才管理系统 - 环境变量配置
# 复制本文件为 .env 并填入实际值
# ==========================================

# ── 服务配置 ──────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# ── MySQL 数据库 ──────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=resume_user
DB_PASSWORD=your_strong_password
DB_NAME=resume_db

# ── 腾讯云 COS 对象存储 ───────────────────
# 在腾讯云控制台 → 访问管理 → API密钥管理 中获取
COS_SECRET_ID=<在腾讯云控制台获取，格式: AKIDxxxxxx>
COS_SECRET_KEY=<在腾讯云控制台获取>
# 存储桶名称（格式: 桶名-AppId，在COS控制台查看）
COS_BUCKET=resumes-1234567890
# 地域（根据存储桶所在地域填写）
# 可选值: ap-beijing / ap-shanghai / ap-guangzhou / ap-chengdu / ap-nanjing 等
COS_REGION=ap-guangzhou

# ── OpenAI（可选，AI简历解析功能）────────
# 也可在系统设置页面中配置，前端配置优先级更高
OPENAI_API_KEY=<你的OpenAI API Key>
OPENAI_BASE_URL=https://api.openai.com/v1
