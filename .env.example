# ==========================================
# 简历人才管理系统 - 环境变量配置
# 复制本文件为 .env 并填入实际值
# ==========================================

# 服务端口（默认 3000）
PORT=3000

# 监听地址（0.0.0.0 表示允许外网访问）
HOST=0.0.0.0

# Node.js 环境
NODE_ENV=production

# OpenAI API 配置（可选，用于AI简历解析功能）
# 也可在系统设置页面中配置，前端配置优先级更高
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
