# ==========================================
# 简历人才管理系统 - 环境变量配置
# 复制本文件为 .env 并填入实际值
# ==========================================

# ── 服务配置 ──────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# ── MySQL 数据库 ──────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=resume_user
DB_PASSWORD=your_strong_password
DB_NAME=resume_db

# ── MinIO 文件服务器 ──────────────────────
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=resumes

# ── OpenAI（可选，AI简历解析功能）────────
# 也可在系统设置页面中配置，前端配置优先级更高
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
